---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DocPrevNext from '../components/DocPrevNext.astro';
import Sidebar from '../components/Sidebar.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
  editUrl?: string;
  pagefindWeight?: string;
}

const {
  title,
  description,
  headings = [],
  editUrl,
  pagefindWeight,
} = Astro.props;
const currentPath =
  Astro.url.pathname.replace(/\.html$/, '').replace(/\/$/, '') || '/';
---

<BaseLayout title={title} description={description}>
  <div class="docs-container">
    <aside class="docs-sidebar">
      <Sidebar currentPath={currentPath} />
    </aside>
    <article class="docs-content" data-pagefind-body data-pagefind-weight={pagefindWeight || undefined}>
      <Breadcrumbs currentPath={currentPath} />
      <h1 data-pagefind-weight={pagefindWeight ? "2" : "10"} data-pagefind-meta="title">{title}</h1>
      <slot />
      {editUrl && (
        <div class="edit-link">
          <a href={editUrl} target="_blank" rel="noopener noreferrer">
            Edit this page
          </a>
        </div>
      )}
      <DocPrevNext currentPath={currentPath} />
    </article>
    {headings.length > 0 && (
      <aside class="docs-toc">
        <nav aria-label="Table of contents">
          <h3>On this page</h3>
          <ul>
            {headings
              .filter((h) => h.depth >= 2 && h.depth <= 3)
              .map((h) => (
                <li class={`toc-depth-${h.depth}`}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
          </ul>
        </nav>
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .docs-container {
    display: grid;
    grid-template-columns: var(--sidebar-width) minmax(0, 1fr) var(--toc-width);
    max-width: 1400px;
    margin: 0 auto;
    min-height: calc(100vh - var(--navbar-height));
    padding-top: var(--navbar-height);
  }

  .docs-sidebar {
    position: sticky;
    top: var(--navbar-height);
    height: calc(100vh - var(--navbar-height));
    overflow-y: auto;
    padding: 1.5rem 1rem;
    border-right: 1px solid var(--color-border);
  }

  .docs-content {
    padding: 2rem 2.5rem;
    max-width: var(--content-max-width);
    width: 100%;
  }

  .docs-content h1 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .docs-content :global(h2) {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .docs-content :global(h3) {
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .docs-content :global(p) {
    margin-bottom: 1rem;
  }

  .docs-content :global(ul),
  .docs-content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .docs-content :global(li) {
    margin-bottom: 0.25rem;
  }

  .docs-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
  }

  .docs-content :global(th),
  .docs-content :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .docs-content :global(th) {
    background: var(--color-bg-secondary);
    font-weight: 600;
  }

  .docs-content :global(blockquote) {
    border-left: 4px solid var(--color-border);
    padding: 0.5rem 1rem;
    margin: 1rem 0;
    color: var(--color-text-secondary);
  }

  .docs-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .docs-content :global(details) {
    margin-bottom: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.75rem 1rem;
  }

  .docs-content :global(summary) {
    cursor: pointer;
    font-weight: 600;
  }

  .edit-link {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .docs-toc {
    position: sticky;
    top: var(--navbar-height);
    height: calc(100vh - var(--navbar-height));
    overflow-y: auto;
    padding: 1.5rem 1rem;
    font-size: 0.85rem;
    border-left: 1px solid var(--color-border);
  }

  .docs-toc h3 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
  }

  .docs-toc ul {
    list-style: none;
    padding: 0;
  }

  .docs-toc li {
    margin-bottom: 0.35rem;
  }

  .docs-toc a {
    color: var(--color-text-secondary);
    text-decoration: none;
    display: block;
    padding: 0.15rem 0;
  }

  .docs-toc a:hover {
    color: var(--color-link);
  }

  .toc-depth-3 {
    padding-left: 0.75rem;
  }

  @media (max-width: 1100px) {
    .docs-toc {
      display: none;
    }
    .docs-container {
      grid-template-columns: var(--sidebar-width) minmax(0, 1fr);
    }
  }

  @media (max-width: 768px) {
    .docs-sidebar {
      display: none;
      position: fixed;
      top: var(--navbar-height);
      left: 0;
      width: 280px;
      height: calc(100vh - var(--navbar-height));
      background: var(--color-bg);
      z-index: 50;
      border-right: 1px solid var(--color-border);
      box-shadow: 4px 0 12px rgba(0, 0, 0, 0.1);
    }

    .docs-sidebar:global(.open) {
      display: block;
    }

    .docs-container {
      grid-template-columns: 1fr;
    }

    .docs-content {
      padding: 1.5rem 1rem;
    }
  }
</style>
