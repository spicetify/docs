---
interface Props {
  visible?: boolean;
}

const { visible = false } = Astro.props;
---

{visible && (
  <div class="sponsor-banner">
    <slot />
  </div>
)}

<style>
  .sponsor-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    text-align: center;
  }
</style>
